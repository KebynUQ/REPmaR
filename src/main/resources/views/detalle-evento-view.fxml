<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="16.0" styleClass="section-wrapper" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="co.edu.uniquindio.eventos.controller.EventoController">
    <children>
        <Label fx:id="nombreEventoLabel" styleClass="section-title" text="Nombre evento" />
        <HBox spacing="12.0">
            <children>
                <Label fx:id="categoriaLabel" styleClass="detail-chip" text="Categoria" />
                <Label fx:id="ciudadLabel" styleClass="detail-chip" text="Ciudad" />
                <Label fx:id="fechaLabel" styleClass="detail-chip" text="Fecha" />
            </children>
        </HBox>
        <Label fx:id="descripcionLabel" styleClass="detail-text" text="Descripcion" wrapText="true" />
        <Label fx:id="recintoLabel" styleClass="detail-text" text="Recinto" wrapText="true" />
        <Label fx:id="politicasLabel" styleClass="detail-text" text="Politicas" wrapText="true" />
        <VBox spacing="10.0" styleClass="detail-panel">
            <children>
                <Label styleClass="panel-title" text="Seleccion de zona y asiento" />
                <ComboBox fx:id="zonaComboBox" onAction="#actualizarAsientos" promptText="Selecciona una zona" />
                <ComboBox fx:id="asientoComboBox" promptText="Selecciona un asiento" />
            </children>
            <padding>
                <Insets bottom="18.0" left="18.0" right="18.0" top="18.0" />
            </padding>
        </VBox>
        <HBox spacing="12.0">
            <children>
                <Button mnemonicParsing="false" onAction="#continuarCompra" styleClass="primary-button" text="Continuar compra" />
                <Button mnemonicParsing="false" onAction="#volverCartelera" styleClass="secondary-button" text="Volver" />
            </children>
        </HBox>
    </children>
</VBox>
